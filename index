<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>스낵큐레이션 — 링키지랩 × 카카오엔터프라이즈</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
:root {
  --yellow: #FFE600;
  --black:  #1A1A1A;
  --white:  #FFFFFF;
  --gray:   #F5F5F5;
  --gray2:  #E8E8E8;
  --text:   #1A1A1A;
  --muted:  #888;
  --font-body: 'Noto Sans KR', sans-serif;
  --radius: 16px;
  --radius-sm: 10px;
}
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--white); color: var(--text); overflow-x: hidden; }

/* NAV */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(255,255,255,0.93);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--gray2);
  padding: 0 48px; height: 60px;
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo { font-size: 15px; font-weight: 700; display: flex; align-items: center; gap: 8px; }
.nav-logo span { background: var(--yellow); color: var(--black); padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; }
.nav-links { display: flex; gap: 28px; list-style: none; }
.nav-links a { font-size: 13px; color: var(--muted); text-decoration: none; transition: color .2s; }
.nav-links a:hover { color: var(--text); }

/* HERO */
.hero { background: var(--black); min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; align-items: center; padding: 80px; gap: 60px; position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; width: 500px; height: 500px; background: var(--yellow); border-radius: 50%; top: -180px; right: -80px; opacity: 0.06; animation: pulse 6s ease-in-out infinite; }
.hero::after { content: ''; position: absolute; width: 250px; height: 250px; background: var(--yellow); border-radius: 50%; bottom: -80px; left: 160px; opacity: 0.04; animation: pulse 8s ease-in-out infinite reverse; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
.hero-text { position: relative; z-index: 1; }
.hero-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,230,0,0.15); border: 1px solid rgba(255,230,0,0.3); color: var(--yellow); font-size: 12px; font-weight: 500; padding: 6px 14px; border-radius: 40px; margin-bottom: 28px; opacity: 0; animation: fadeUp .6s ease .2s forwards; }
.hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--yellow); border-radius: 50%; animation: blink 1.5s ease infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
.hero h1 { font-size: clamp(34px, 4.5vw, 52px); font-weight: 900; color: var(--white); line-height: 1.15; margin-bottom: 20px; opacity: 0; animation: fadeUp .7s ease .35s forwards; }
.hero h1 em { color: var(--yellow); font-style: normal; }
.hero-desc { font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.8; font-weight: 300; margin-bottom: 40px; opacity: 0; animation: fadeUp .7s ease .5s forwards; }
.hero-meta { font-size: 12px; color: rgba(255,255,255,0.3); font-weight: 300; letter-spacing: 0.06em; margin-bottom: 40px; opacity: 0; animation: fadeUp .7s ease .55s forwards; }
.hero-cta { display: flex; gap: 12px; opacity: 0; animation: fadeUp .7s ease .65s forwards; }
.btn-primary { background: var(--yellow); color: var(--black); font-size: 13px; font-weight: 700; padding: 14px 28px; border-radius: 40px; border: none; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: transform .2s; }
.btn-primary:hover { transform: translateY(-2px); }
.btn-ghost { background: transparent; color: rgba(255,255,255,0.6); font-size: 14px; font-weight: 400; padding: 14px 24px; border-radius: 40px; border: 1px solid rgba(255,255,255,0.2); cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: border-color .2s, color .2s, transform .2s; }
.btn-ghost:hover { border-color: rgba(255,255,255,0.5); color: var(--white); transform: translateY(-2px); }
.hero-stats { display: flex; gap: 32px; margin-top: 52px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1); opacity: 0; animation: fadeUp .7s ease .8s forwards; }
.stat { display: flex; flex-direction: column; gap: 4px; }
.stat-val { font-size: 26px; font-weight: 700; color: var(--yellow); }
.stat-lbl { font-size: 11px; color: rgba(255,255,255,0.4); font-weight: 300; }

/* HERO VISUAL */
.hero-visual { position: relative; z-index: 1; display: flex; justify-content: center; opacity: 0; animation: fadeLeft .8s ease .4s forwards; }
@keyframes fadeLeft { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
.phone-frame { width: 260px; background: #111; border-radius: 36px; border: 2px solid #333; padding: 10px; box-shadow: 0 40px 80px rgba(0,0,0,0.5); }
.phone-notch { width: 72px; height: 22px; background: #111; border-radius: 0 0 14px 14px; margin: 0 auto 8px; }
.phone-screen { background: #FAFAFA; border-radius: 26px; overflow: hidden; min-height: 500px; }
.app-header { background: var(--black); padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; }
.app-logo { font-size: 14px; font-weight: 700; color: var(--white); display: flex; align-items: center; gap: 6px; }
.app-logo-dot { width: 7px; height: 7px; background: var(--yellow); border-radius: 50%; animation: blink 1.5s ease infinite; }
.app-header-icon { width: 28px; height: 28px; background: rgba(255,255,255,0.1); border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 13px; }
.mockup-cards { position: absolute; right: -16px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 10px; }
.float-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 12px; width: 130px; animation: floatCard 4s ease-in-out infinite; }
.float-card:nth-child(2) { animation-delay: 1.5s; }
.float-card:nth-child(3) { animation-delay: 3s; }
@keyframes floatCard { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
.float-val { font-size: 20px; font-weight: 700; color: var(--yellow); }
.float-lbl { font-size: 9px; color: rgba(255,255,255,0.4); font-weight: 300; margin-top: 2px; }

/* SECTION COMMON */
section { padding: 100px 80px; }
.section-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
.section-title { font-size: clamp(26px, 3vw, 40px); font-weight: 900; color: var(--text); line-height: 1.2; margin-bottom: 16px; }
.section-desc { font-size: 15px; color: var(--muted); line-height: 1.8; font-weight: 300; max-width: 560px; margin-bottom: 56px; }

/* FEATURES */
#features { background: var(--gray); }
.features-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.feature-card { background: var(--white); border-radius: var(--radius); padding: 28px 22px; opacity: 0; transform: translateY(30px); transition: opacity .5s ease, transform .5s ease; }
.feature-card.visible { opacity: 1; transform: translateY(0); }
.feature-card:nth-child(2).visible { transition-delay: .1s; }
.feature-card:nth-child(3).visible { transition-delay: .2s; }
.feature-card:nth-child(4).visible { transition-delay: .3s; }
.feature-card:hover { transform: translateY(-6px); }
.feature-icon { width: 44px; height: 44px; background: var(--yellow); border-radius: 11px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 18px; }
.feature-name { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.feature-desc { font-size: 13px; color: var(--muted); line-height: 1.7; font-weight: 300; }

/* PROCESS */
#process { background: var(--white); }

/* OPERATIONS */
#operations { background: var(--black); }
#operations .section-title { color: var(--white); }
#operations .section-desc { color: rgba(255,255,255,0.45); }
#operations .section-tag { color: rgba(255,255,255,0.3); }
.ops-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.ops-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius); padding: 26px 22px; opacity: 0; transform: translateY(20px); transition: opacity .5s ease, transform .5s ease, background .3s; }
.ops-card.visible { opacity: 1; transform: translateY(0); }
.ops-card:nth-child(2).visible { transition-delay: .15s; }
.ops-card:nth-child(3).visible { transition-delay: .3s; }
.ops-card:hover { background: rgba(255,230,0,0.07); }
.ops-card-title { font-size: 15px; font-weight: 700; color: var(--white); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
.ops-dot { width: 7px; height: 7px; background: var(--yellow); border-radius: 50%; }
.ops-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 12px; }
.ops-row:last-child { border-bottom: none; }
.ops-row .k { color: rgba(255,255,255,0.4); font-weight: 300; }
.ops-row .v { color: var(--white); font-weight: 500; }
.events-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 48px; align-items: center; }
.event-chip { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 40px; padding: 7px 14px; transition: background .2s; }
.event-chip:hover { background: rgba(255,230,0,0.12); }
.event-q { font-size: 10px; font-weight: 700; color: var(--yellow); letter-spacing: 0.05em; }
.event-name { font-size: 12px; color: var(--white); font-weight: 400; }

/* TRANSPARENCY */
#transparency { background: var(--gray); }
.transp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
.transp-card { background: var(--white); border-radius: var(--radius); padding: 28px 22px; opacity: 0; transform: translateY(20px); transition: opacity .5s, transform .5s; }
.transp-card.visible { opacity: 1; transform: translateY(0); }
.transp-card:nth-child(2).visible { transition-delay: .1s; }
.transp-card:nth-child(3).visible { transition-delay: .2s; }
.transp-badge { display: inline-block; background: var(--yellow); color: var(--black); font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 4px; margin-bottom: 14px; }
.transp-body { font-size: 13px; color: var(--muted); line-height: 1.7; font-weight: 300; }
.op-block { background: var(--yellow); border-radius: var(--radius); padding: 28px 32px; display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: start; }
.op-label { font-size: 10px; font-weight: 700; color: var(--yellow); background: var(--black); display: inline-block; padding: 3px 10px; border-radius: 4px; margin-bottom: 12px; }
.op-title { font-size: 20px; font-weight: 900; color: var(--black); line-height: 1.3; margin-bottom: 8px; }
.op-desc { font-size: 11px; color: rgba(0,0,0,0.5); }
.op-quarters { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.q-card { background: var(--white); border-radius: 8px; padding: 14px 10px; text-align: center; min-width: 90px; border: 1.5px solid rgba(0,0,0,0.08); }
.q-card.highlight { border: 2px solid var(--black); }
.q-tag { font-size: 9px; color: #888; margin-bottom: 6px; }
.q-icon { font-size: 22px; margin-bottom: 6px; }
.q-lbl { font-size: 11px; font-weight: 700; color: var(--black); line-height: 1.3; }

/* CHAT SECTION */
.chat-section { background: var(--black); padding: 100px 80px; }
.chat-section .section-tag { color: rgba(255,255,255,0.3); }
.chat-section .section-title { color: var(--white); }
.chat-section .section-desc { color: rgba(255,255,255,0.45); }
.chat-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
.chat-mockup-outer { display: flex; justify-content: center; }
.chat-device { width: 320px; background: #1A1A1A; border-radius: 24px; border: 1px solid rgba(255,255,255,0.08); overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.6); }
.chat-device-bar { background: #FFE600; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; }
.chat-device-title { font-size: 13px; font-weight: 700; color: var(--black); }
.chat-device-sub { font-size: 10px; color: rgba(0,0,0,0.5); margin-top: 1px; }
.chat-device-icon { font-size: 18px; }
.chat-device-body { padding: 18px 14px; display: flex; flex-direction: column; gap: 10px; background: #111; }
.chat-ts { font-size: 9px; color: rgba(255,255,255,0.25); text-align: center; margin: 2px 0; }
.chat-msg { display: flex; flex-direction: column; gap: 3px; max-width: 82%; }
.chat-msg.me { align-self: flex-end; align-items: flex-end; }
.chat-msg.them { align-self: flex-start; align-items: flex-start; }
.chat-name { font-size: 9px; color: rgba(255,255,255,0.35); padding: 0 4px; }
.chat-bbl { padding: 10px 13px; border-radius: 14px; font-size: 11px; line-height: 1.6; }
.chat-msg.them .chat-bbl { background: #2A2A2A; color: rgba(255,255,255,0.85); border-bottom-left-radius: 3px; }
.chat-msg.me .chat-bbl { background: #FFE600; color: #1A1A1A; border-bottom-right-radius: 3px; font-weight: 600; }
.chat-reaction { font-size: 10px; color: rgba(255,255,255,0.35); padding: 0 4px; }
.chat-text-side { }
.chat-point { margin-bottom: 28px; opacity: 0; transform: translateX(20px); transition: opacity .5s, transform .5s; }
.chat-point.visible { opacity: 1; transform: translateX(0); }
.chat-point:nth-child(2).visible { transition-delay: .12s; }
.chat-point:nth-child(3).visible { transition-delay: .24s; }
.chat-point-icon { font-size: 24px; margin-bottom: 10px; }
.chat-point-title { font-size: 16px; font-weight: 700; color: var(--white); margin-bottom: 6px; }
.chat-point-desc { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; font-weight: 300; }
.chat-highlight { display: inline-block; background: rgba(255,230,0,0.15); border: 1px solid rgba(255,230,0,0.3); color: var(--yellow); font-size: 12px; font-weight: 600; padding: 5px 14px; border-radius: 40px; margin-top: 28px; }

/* DASHBOARD SECTION */
.dashboard-section { background: #F0F2F5; padding: 100px 80px; }
.dashboard-section .section-tag { color: var(--muted); }
.dashboard-section .section-title { color: var(--black); }
.dashboard-section .section-desc { color: var(--muted); }
.dash-wrap { background: #F0F2F5; border-radius: 20px; overflow: hidden; display: flex; box-shadow: 0 20px 60px rgba(0,0,0,0.12); min-height: 820px; font-family: 'Noto Sans KR', sans-serif; }
.dash-sidebar { width: 148px; background: #fff; display: flex; flex-direction: column; flex-shrink: 0; border-right: 1px solid #E8E8E8; }
.dash-logo { padding: 22px 16px 18px; border-bottom: 1px solid #F0F0F0; }
.dash-logo-main { font-size: 20px; font-weight: 900; color: #1A1A1A; line-height: 1; }
.dash-logo-main span { color: #FFD700; }
.dash-logo-sub { font-size: 9px; font-weight: 700; color: #aaa; letter-spacing: 0.15em; margin-top: 2px; }
.dash-nav { flex: 1; padding: 10px 0; }
.dash-nav-item { display: flex; align-items: center; gap: 8px; padding: 11px 16px; font-size: 12px; font-weight: 500; color: #666; cursor: pointer; transition: background .15s; border-radius: 10px; margin: 2px 8px; }
.dash-nav-item:hover { background: #F5F5F5; }
.dash-nav-item.active { background: #FFE600; color: #1A1A1A; font-weight: 700; }
.dash-nav-icon { font-size: 15px; width: 18px; text-align: center; }
.dash-bottom { padding: 14px 12px 16px; border-top: 1px solid #F0F0F0; }
.dash-msg { font-size: 10px; color: #888; line-height: 1.6; margin-bottom: 12px; }
.dash-msg strong { color: #FFB800; }
.dash-character { font-size: 36px; text-align: center; }
.dash-main { flex: 1; overflow: hidden; display: flex; flex-direction: column; }
.dash-topbar { background: #fff; border-bottom: 1px solid #EBEBEB; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; }
.dash-topbar-date { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #555; background: #F5F5F5; border-radius: 8px; padding: 6px 12px; }
.dash-topbar-date span { font-weight: 600; color: #222; }
.dash-topbar-live { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #555; }
.live-dot { width: 7px; height: 7px; background: #4CAF50; border-radius: 50%; animation: blink 1.5s ease infinite; }
.dash-content { flex: 1; padding: 20px 22px; overflow-y: auto; background: #F4F5F7; display: flex; flex-direction: column; gap: 16px; }
.dash-kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.dash-kpi { background: #fff; border-radius: 14px; padding: 16px 18px; display: flex; align-items: center; gap: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
.dash-kpi-icon { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.kpi-yellow { background: #FFF3CC; }
.kpi-red    { background: #FFF0EE; }
.kpi-purple { background: #F0EEFF; }
.dash-kpi-info { flex: 1; }
.dash-kpi-label { font-size: 11px; color: #888; font-weight: 400; margin-bottom: 4px; }
.dash-kpi-val { font-size: 20px; font-weight: 900; color: #1A1A1A; line-height: 1; margin-bottom: 5px; }
.dash-kpi-val span { font-size: 12px; font-weight: 500; margin-left: 2px; }
.dash-kpi-delta { font-size: 11px; color: #888; }
.dash-kpi-delta .up { color: #2ECC71; font-weight: 600; }
.dash-kpi-delta .dn { color: #E74C3C; font-weight: 600; }
.dash-chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: stretch; }
.dash-card { background: #fff; border-radius: 14px; padding: 16px 18px; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
.dash-chart-row .dash-card { display: flex; flex-direction: column; min-height: 230px; }
.dash-card-title { font-size: 13px; font-weight: 700; color: #1A1A1A; margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
.dash-card-title .sub { font-size: 10px; font-weight: 400; color: #aaa; }
.bar-chart-outer { display: flex; gap: 0; flex: 1; align-items: stretch; min-height: 160px; }
.bar-chart-yaxis { display: flex; flex-direction: column; justify-content: space-between; padding-bottom: 22px; padding-right: 6px; color: #bbb; font-size: 9px; text-align: right; flex-shrink: 0; width: 36px; line-height: 1; }
.bar-chart-wrap { position: relative; flex: 1; display: flex; align-items: flex-end; gap: 3px; padding-bottom: 22px; border-bottom: 1px solid #EEEEEE; overflow: visible; }
.bar-chart-grid { position: absolute; left: 0; right: 0; top: 0; bottom: 22px; display: flex; flex-direction: column; justify-content: space-between; pointer-events: none; z-index: 0; }
.bar-chart-grid-line { width: 100%; height: 1px; background: #F2F2F2; }
.bar-col { display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 3px; flex: 1; position: relative; z-index: 1; min-width: 0; }
.bar { width: 78%; border-radius: 3px 3px 0 0; min-width: 4px; transition: opacity .15s; }
.bar:hover { opacity: 0.8; }
.bar.past { background: #B8CBF5; }
.bar.curr { background: #FFD600; }
.bar.fut  { background: #DCDCDC; }
.bar-lbl  { font-size: 8px; color: #bbb; line-height: 1; white-space: nowrap; }
.bar-curr-lbl { position: absolute; top: -17px; left: 50%; transform: translateX(-50%); background: #FFD600; color: #1A1A1A; font-size: 8px; font-weight: 700; padding: 2px 5px; border-radius: 4px; white-space: nowrap; z-index: 2; }
.dash-bottom-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr; gap: 10px; }
.dash-top5 .top5-item { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid #F8F8F8; }
.dash-top5 .top5-item:last-child { border-bottom: none; }
.top5-rank { font-size: 11px; font-weight: 700; color: #FFB800; width: 14px; text-align: center; flex-shrink: 0; }
.top5-name { font-size: 11px; color: #333; flex: 1; font-weight: 400; }
.top5-bar-wrap { width: 50px; height: 5px; background: #F0F0F0; border-radius: 3px; flex-shrink: 0; }
.top5-bar-fill { height: 5px; border-radius: 3px; background: #FFD600; }
.top5-val { font-size: 10px; color: #aaa; width: 36px; text-align: right; flex-shrink: 0; }
.stock-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 10px; }
.stock-badge { border-radius: 8px; padding: 10px; text-align: center; }
.stock-badge.ok  { background: #F0FFF4; border: 1px solid #C6F6D5; }
.stock-badge.warn{ background: #FFF5F5; border: 1px solid #FED7D7; }
.stock-badge-icon { font-size: 14px; }
.stock-badge-lbl { font-size: 9px; color: #666; margin: 3px 0 1px; font-weight: 500; }
.stock-badge-val { font-size: 15px; font-weight: 900; color: #1A1A1A; }
.stock-badge-unit { font-size: 9px; color: #aaa; }
.stock-sub-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.stock-sub { background: #F8F8F8; border-radius: 8px; padding: 8px; text-align: center; }
.stock-sub-icon { font-size: 12px; }
.stock-sub-lbl { font-size: 8px; color: #999; margin: 2px 0 1px; }
